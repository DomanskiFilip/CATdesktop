{
  "$schema": "https://schema.tauri.app/config/2",
  "version": "1.0.0-beta",
  "identifier": "com.calendarassistant.casual",
  "productName": "Calendar Assistant",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "catdesktop",
        "width": 1280,
        "height": 680,
        "resizable": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/ios/icon-20.png",
      "icons/ios/icon-29.png",
      "icons/ios/icon-40.png",
      "icons/ios/icon-60.png",
      "icons/ios/icon-76.png",
      "icons/ios/icon-1024.png"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": "Developer: DomanskiFilip",
      "providerShortName": null,
      "entitlements": null
    },
    "iOS": {
      "developmentTeam": "${IOS_DEVELOPMENT_TEAM}",
      "minimumSystemVersion": "18.6"
    }
  }
}