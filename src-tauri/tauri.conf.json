{
  "$schema": "https://schema.tauri.app/config/2",
  "version": "1.2.3",
  "identifier": "com.calendarassistant.casual",
  "productName": "CAT - Calendar Assistant (Beta)",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CAT - Calendar Assistant",
        "width": 1280,
        "height": 680,
        "resizable": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/ios/AppIcon-20x20@1x.png",
      "icons/ios/AppIcon-29x29@1x.png",
      "icons/ios/AppIcon-40x40@1x.png",
      "icons/ios/AppIcon-60x60@2x.png",
      "icons/ios/AppIcon-76x76@1x.png",
      "icons/ios/AppIcon-512@2x.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": ["en-US"],
        "bannerPath": "wix/banner.bmp",
        "dialogImagePath": "wix/dialog.bmp"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": "Developer: DomanskiFilip",
      "providerShortName": null,
      "entitlements": null
    },
    "iOS": {
      "developmentTeam": "${IOS_DEVELOPMENT_TEAM}",
      "minimumSystemVersion": "18.6"
    }
  }
}